<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<h1 class="h3 mb-4"><%= title %></h1>

<form action="/workouts/<%= workout._id %>?_method=PUT" method="POST" class="card p-4 shadow-sm bg-white">
  <div class="mb-3">
    <label class="form-label" for="name">Workout Name</label>
    <input
      type="text"
      class="form-control"
      id="name"
      name="name"
      value="<%= workout.name %>"
      required>
  </div>

  <div class="mb-3">
    <label class="form-label" for="category">Category</label>
    <select class="form-select" id="category" name="category">
      <option value="Cardio" <%= workout.category === 'Cardio' ? 'selected' : '' %>>Cardio</option>
      <option value="Strength" <%= workout.category === 'Strength' ? 'selected' : '' %>>Strength</option>
      <option value="Flexibility" <%= workout.category === 'Flexibility' ? 'selected' : '' %>>Flexibility</option>
      <option value="Other" <%= workout.category === 'Other' ? 'selected' : '' %>>Other</option>
    </select>
  </div>

  <div class="mb-3">
    <label class="form-label" for="duration">Duration (minutes)</label>
    <input
      type="number"
      class="form-control"
      id="duration"
      name="duration"
      min="1"
      value="<%= workout.duration %>"
      required>
  </div>

  <div class="mb-3">
    <label class="form-label" for="date">Date</label>
    <input
      type="date"
      class="form-control"
      id="date"
      name="date"
      value="<%= workout.date.toISOString().slice(0,10) %>"
      required>
  </div>

  <div class="mb-3">
    <label class="form-label" for="notes">Notes (optional)</label>
    <textarea class="form-control" id="notes" name="notes" rows="3"><%= workout.notes %></textarea>
  </div>

  <div class="d-flex justify-content-between">
    <a href="/workouts" class="btn btn-secondary">Back</a>
    <button type="submit" class="btn btn-primary">Update Workout</button>
  </div>
</form>

<%- include('../partials/footer') %>
