<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-5">
  <h1 class="mb-4">All Workouts</h1>

  <%- include('../partials/messages') %>

  <% if (workouts.length === 0) { %>
    <p class="empty-text">No workouts found.</p>
  <% } else { %>
    <div class="row">
      <% workouts.forEach(function(w) { %>
        <div class="col-md-4 mb-3">
          <div class="card workout-card h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= w.title %></h5>
              <p class="card-text small text-muted">
                <%= w.type %> • <%= w.duration %> min •
                <%= w.date.toDateString() %>
              </p>
              <p class="card-text flex-grow-1"><%= w.notes ? w.notes.substring(0, 80) : '' %></p>
              <div class="mt-auto">
                <a href="/workouts/<%= w._id %>" class="btn btn-sm btn-outline-primary me-2">Details</a>

                <% if (currentUser && w.createdBy && w.createdBy.toString() === currentUser.id) { %>
                  <a href="/workouts/<%= w._id %>/edit" class="btn btn-sm btn-primary me-2">Edit</a>

                  <form
                    action="/workouts/<%= w._id %>?_method=DELETE"
                    method="POST"
                    class="d-inline"
                    onsubmit="return confirm('Are you sure you want to delete this workout?');"
                  >
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
