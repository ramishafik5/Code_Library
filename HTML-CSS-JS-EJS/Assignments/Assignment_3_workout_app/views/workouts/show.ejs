<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="h3"><%= title %></h1>
  <a href="/workouts/new" class="btn btn-success">+ Add Workout</a>
</div>

<% if (workouts.length === 0) { %>
  <div class="alert alert-info">
    No workouts found. Click "Add Workout" to create your first one.
  </div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-striped align-middle bg-white">
      <thead>
        <tr>
          <th>Date</th>
          <th>Name</th>
          <th>Category</th>
          <th>Duration (min)</th>
          <th>Notes</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% workouts.forEach(function(workout) { %>
          <tr>
            <td><%= workout.date.toLocaleDateString() %></td>
            <td><%= workout.name %></td>
            <td><%= workout.category %></td>
            <td><%= workout.duration %></td>
            <td><%= workout.notes || '-' %></td>
            <td class="text-end">
              <a href="/workouts/<%= workout._id %>/edit" class="btn btn-sm btn-primary">Edit</a>
              <a href="/workouts/<%= workout._id %>/delete" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('../partials/footer') %>
